<IfModule mod_rewrite.c>
  RewriteEngine On

  # 1. Forward any /api/xxx requests to api.php?route=xxx
  # This works perfectly regardless of whether the app is in root or a subdirectory!
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^api/(.*)$ api.php?route=$1 [QSA,L]

  # 2. Prevent rewriting if it's direct access to key backend files
  RewriteRule ^api\.php$ - [L]
  RewriteRule ^install\.php$ - [L]
  RewriteRule ^db_config\.php$ - [L]
  RewriteRule ^.*\.sqlite$ - [L]

  # 3. Force root and index.html to serve from the compiled dist/ directory
  # This ensures we bypass the uncompiled root index.html file!
  RewriteRule ^$ dist/index.html [L]
  RewriteRule ^index\.html$ dist/index.html [L]

  # 4. Serve physical files from dist folder if they exist there
  # (e.g., assets/index-xxx.js -> dist/assets/index-xxx.js)
  RewriteCond %{DOCUMENT_ROOT}/$1 -f
  RewriteRule ^(dist/.*)$ $1 [L]

  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_URI} !^/dist/
  RewriteRule ^(.*)$ dist/$1 [L]

  # 5. Support standard SPA React routing fallback to dist/index.html
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . dist/index.html [L]
</IfModule>

# Block direct access to SQLite database files for complete security!
<FilesMatch "\.sqlite$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>
